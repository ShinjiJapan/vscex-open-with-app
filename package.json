{
  "name": "open-with-app",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "publisher": "shinjijapan",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ShinjiJapan/vscex-open-with-app"
  },
  "license": "MIT",
  "version": "1.2.0",
  "l10n": "./l10n",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "open with",
    "external application",
    "explorer context menu",
    "file association",
    "default application",
    "launch app",
    "store app",
    "windows"
  ],
  "main": "./extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "openWithApp.open",
        "title": "%openWithApp.open.title%"
      },
      {
        "command": "openWithApp.openWith",
        "title": "%openWithApp.openWith.title%"
      },
      {
        "command": "openWithApp.manage",
        "title": "%openWithApp.manage.title%"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "openWithApp.open",
          "group": "openWithApp@1"
        },
        {
          "command": "openWithApp.openWith",
          "group": "openWithApp@2"
        }
      ],
      "commandPalette": [
        {
          "command": "openWithApp.open",
          "when": "false"
        },
        {
          "command": "openWithApp.openWith",
          "when": "false"
        },
        {
          "command": "openWithApp.manage",
          "when": "true"
        }
      ]
    }
  }
}
